{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git show*)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm install*)",
      "Bash(python -m pytest*)",
      "Bash(python -m ruff*)",
      "Bash(python -m mypy*)",
      "Bash(ruff*)",
      "Bash(mypy*)",
      "Bash(find . *)",
      "Bash(grep *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(docker build*)",
      "Bash(docker run*)",
      "Bash(docker ps*)",
      "Bash(docker images*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/Malodeity && (ruff check --quiet \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/Malodeity && echo \"--- Session summary ---\" && git branch --show-current && git log --oneline -3 && git status --short"
          }
        ]
      }
    ]
  },
  "cleanupPeriodDays": 1,
  "includeCoAuthoredBy": false
}
